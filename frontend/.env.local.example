# Local dev: point to your local FastAPI backend (use 8001 if 8000 is blocked on Windows)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8001
BACKEND_URL=http://127.0.0.1:8001

# Vercel (Production + Preview): set BACKEND_URL to your Railway URL (with https://)
BACKEND_URL=https://spotify-review-discovery-engine-production.up.railway.app
# Optional — only needed if you call the API from server-side code directly
# NEXT_PUBLIC_API_URL=https://spotify-review-discovery-engine-production.up.railway.app
# Do NOT include /api at the end — the proxy adds it automatically.
