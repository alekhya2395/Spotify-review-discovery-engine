# =========================================
# Phase 1 — Data Collection: Environment
# Copy to `.env` and fill in real values.
# =========================================

# ---- Spotify identifiers ----
# iOS App Store numeric ID (Spotify = 324684580)
SPOTIFY_APP_STORE_ID=324684580
# Android Play Store package name
SPOTIFY_PLAY_STORE_ID=com.spotify.music

# ---- Reddit (PRAW) ----
# Create an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=spotify-review-engine/0.1 by u/yourname
# Comma-separated subreddits to crawl
REDDIT_SUBREDDITS=spotify,truespotify,Music

# ---- Spotify Community Forum ----
COMMUNITY_BASE_URL=https://community.spotify.com

# ---- Collection settings ----
# Where to write raw data
RAW_DATA_DIR=./data/raw
# Max reviews per source per run (safety cap)
MAX_REVIEWS_PER_SOURCE=2000
# Languages/countries for app store reviews (comma-separated)
APP_STORE_COUNTRIES=us,gb,in
PLAY_STORE_LANGS=en
PLAY_STORE_COUNTRIES=us,gb,in

# ---- Reliability ----
REQUEST_TIMEOUT_SECONDS=20
RETRY_MAX_ATTEMPTS=4
RETRY_BACKOFF_SECONDS=2

# ---- Logging ----
LOG_LEVEL=INFO
LOG_DIR=./logs

# =========================================
# Phase 2 — AI Analysis (Groq + Llama 3.3 70B)
# =========================================

# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
# Model id (https://console.groq.com/docs/models)
GROQ_MODEL=llama-3.3-70b-versatile
# Number of reviews packed into one LLM call
GROQ_BATCH_SIZE=10
# Sampling temperature (0 = deterministic)
GROQ_TEMPERATURE=0
# Max output tokens per call
GROQ_MAX_TOKENS=4000

# Where Phase 2 writes its outputs
PROCESSED_DATA_DIR=./data/processed
# Filename for the rolling insights CSV
INSIGHTS_CSV=insights.csv
# Hard cap on number of reviews analyzed per run (0 = no cap)
MAX_REVIEWS_PER_ANALYSIS_RUN=0

# =========================================
# Phase 3 — Topic Modeling & Clustering
# =========================================

# Sentence-Transformers model id (CPU-friendly, 80 MB)
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Batch size for embedding (32 is a safe CPU default)
EMBED_BATCH_SIZE=64

# BERTopic / HDBSCAN — controls topic granularity.
# Lower => more, smaller topics. Higher => fewer, broader topics.
MIN_CLUSTER_SIZE=8
# UMAP target dimensionality before HDBSCAN
UMAP_N_COMPONENTS=5
UMAP_N_NEIGHBORS=10
# How many top reviews per topic to keep as evidence quotes
TOP_DOCS_PER_TOPIC=5
# When true, ask the LLM to generate a human-friendly label for each topic
LLM_TOPIC_LABELS=true
# Only cluster discovery-related insights (true) or all of them (false)
CLUSTER_DISCOVERY_ONLY=false

# Output paths
TOPICS_CSV=topics.csv
INSIGHTS_WITH_TOPICS_CSV=insights_with_topics.csv
EMBEDDINGS_NPY=embeddings.npy
EMBEDDING_INDEX_CSV=embedding_index.csv
TOPIC_MODEL_DIR=topic_model

# =========================================
# Phase 4 — Insight Generation (PM-ready cards)
# =========================================

# Minimum cluster size to synthesize a card (skip smaller topics)
PHASE4_MIN_TOPIC_SIZE=10
# Max verbatim quotes attached to each card
PHASE4_MAX_EVIDENCE_QUOTES=8
# Include BERTopic noise bucket (topic_id=-1)
PHASE4_INCLUDE_NOISE=false
# Only generate cards for discovery-heavy clusters
PHASE4_DISCOVERY_ONLY=false
PHASE4_MIN_DISCOVERY_SHARE_PCT=50
# When true, use Groq RAG to synthesize cards; false = rule-based only
PHASE4_USE_LLM_CARDS=true

INSIGHT_CARDS_CSV=insight_cards.csv
INSIGHT_CARDS_JSON=insight_cards.json

# =========================================
# Phase 5 — Storage & Indexing
# =========================================
PHASE5_WAREHOUSE_DB=warehouse.duckdb
PHASE5_CATALOG_DB=catalog.db
PHASE5_CHROMA_DIR=chroma
PHASE5_CHROMA_COLLECTION=review_embeddings
PHASE5_DEFAULT_SEARCH_K=10
# Index output directory (DuckDB + Chroma + SQLite catalog)
INDEX_DATA_DIR=./data/index

# =========================================
# Phase 6 — Visualization & Delivery
# =========================================
PHASE6_APP_TITLE=Spotify Review Discovery Engine
PHASE6_DEFAULT_CARD_LIMIT=53
PHASE6_DEFAULT_SEARCH_K=10
PHASE6_CHAT_CONTEXT_K=8
PHASE6_ENABLE_CHAT=true
PHASE6_EXPORT_DIR=./data/exports
