# Required for /api/chat (copy from project root .env or get key at https://console.groq.com/keys)
GROQ_API_KEY=
# Chat uses the faster 8b model by default to reduce token usage and rate-limit errors.
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# CORS - comma-separated list of allowed origins for the frontend
# In production, set this to your Vercel URL, e.g.:
# ALLOWED_ORIGINS=https://spotify-discovery-insights.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Path where bundled data files live (relative to backend/ when deployed)
DATA_DIR=./data
